# Postgres (used by db container and by matchmaker-backend / game-backend)
POSTGRES_DB=nexin
POSTGRES_USER=nexin
POSTGRES_PASSWORD=nexin

# -----------------------------------------------------------------------------
# Hostnames / URLs: set for LOCAL (default) or PRODUCTION (deploy)
# -----------------------------------------------------------------------------
# Local development (default): frontends and APIs on localhost with various ports.
# Production (e.g. deploy): use your public hostnames. Example mapping:
#   matchmaker.loki-console.com     -> matchmaker-frontend
#   matchmaker-api.loki-console.com -> matchmaker-backend
#   game.loki-console.com           -> game-frontend
#   game-api.loki-console.com       -> game-backend
#
# For LOCAL, leave the optional vars below unset or use the values in the
# "Local development" block. For PRODUCTION, set them as in the "Production" block.
# -----------------------------------------------------------------------------

# --- Local development (default) ---
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://matchmaker-frontend:5173,http://localhost:5174,http://127.0.0.1:5174,http://game-frontend:5174
# GAME_FRONTEND_URL=http://localhost:5174
# DISCORD_FRONTEND_REDIRECT=http://localhost:5173/discord-callback
# DISCORD_FRONTEND_REDIRECT_LINK=http://localhost:5173/discord-link-callback
# VITE_DISCORD_AUTHORIZE_URL=http://localhost:8000
# VITE_API_URL=
# VITE_WS_URL=
# VITE_GAME_API_URL=
# MATCHMAKER_FRONTEND_URL=

# --- Production (loki-console.com example) ---
# Uncomment and set when deploying. Also add these redirect URLs in Discord OAuth2:
#   https://matchmaker.loki-console.com/discord-callback
#   https://matchmaker.loki-console.com/discord-link-callback
# CORS_ORIGINS=https://matchmaker.loki-console.com,https://game.loki-console.com
# GAME_FRONTEND_URL=https://game.loki-console.com
# DISCORD_FRONTEND_REDIRECT=https://matchmaker.loki-console.com/discord-callback
# DISCORD_FRONTEND_REDIRECT_LINK=https://matchmaker.loki-console.com/discord-link-callback
# VITE_DISCORD_AUTHORIZE_URL=https://matchmaker-api.loki-console.com
# VITE_API_URL=https://matchmaker-api.loki-console.com
# VITE_WS_URL=wss://matchmaker-api.loki-console.com
# VITE_GAME_API_URL=https://game-api.loki-console.com
# MATCHMAKER_FRONTEND_URL=https://matchmaker.loki-console.com

# Discord (same application: OAuth2 + Bot)
# Create an application at https://discord.com/developers/applications
# OAuth2: add redirect URLs (see CORS / Production section above for production URLs)
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_FRONTEND_REDIRECT=http://localhost:5173/discord-callback
DISCORD_FRONTEND_REDIRECT_LINK=http://localhost:5173/discord-link-callback

# Optional: frontend env (Vite exposes VITE_* to the client)
# Leave empty for local (same-origin). Set to API base URL when frontend and backend are on different origins (e.g. deploy).
VITE_DISCORD_AUTHORIZE_URL=http://localhost:8000

# Bot: Bot tab → Token → DISCORD_BOT_TOKEN. General Information → Public Key → DISCORD_PUBLIC_KEY.
# Interactions → Interactions Endpoint URL → https://your-backend/api/v1/discord/interactions/
# Invite bot with scope bot + applications.commands and permissions: send messages, create threads (public/private),
# create polls, mention everyone, add reactions, use slash commands, create and manage events.
# Permission value: use BOT_INVITE_PERMISSIONS.value from discord-bot/bot.py in the invite URL &permissions=...
# Run: python manage.py register_discord_commands
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_PUBLIC_KEY=your_discord_public_key
# Optional: base URL for matchmaker frontend (linked in /lfg Discord reply)
MATCHMAKER_FRONTEND_URL=https://your-matchmaker.example.com

# Game backend: matchmaker app credentials (from matchmaker Apps page; used to register with matchmaker)
MATCHMAKING_APP_ID=your_matchmaker_app_id
MATCHMAKING_SECRET=your_matchmaker_app_secret
